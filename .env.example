# Default mode is dry-run. Real buys require all three switches:
# DRY_RUN=0
# EXECUTE=1
# I_UNDERSTAND_42_PRICE_MARKET_RISK=YES
# I_AM_NOT_IN_RESTRICTED_JURISDICTION=YES
DRY_RUN=1
EXECUTE=0
I_UNDERSTAND_42_PRICE_MARKET_RISK=NO
I_AM_NOT_IN_RESTRICTED_JURISDICTION=NO

FORTYTWO_REST_URL=https://rest.ft.42.space
# Project env overrides ~/.codex/secrets/evm-rpc-providers.env.
# Supported HTTP aliases: BSC_RPC_URL, CHAINSTACK_BSC_RPC_URL, ANKR_BSC_RPC_URL.
# Supported WSS aliases: BSC_WS_URL, CHAINSTACK_BSC_WS_URL, ANKR_BSC_WS_URL, ANKR_BSC_WS_RPC_URL.
# Binance dataseed rejects eth_getLogs; publicnode supports controller event discovery.
BSC_RPC_URL=https://bsc-rpc.publicnode.com
BSC_WS_URL=wss://bsc-rpc.publicnode.com
PRIVATE_KEY=
WALLET_ADDRESS=
PRIVATE_KEY_KEYCHAIN_SERVICE=42space-event-bot-private-key
PRIVATE_KEY_KEYCHAIN_ACCOUNT=42space
DISABLE_KEYCHAIN_PRIVATE_KEY=0
WINDOWS_DPAPI_PRIVATE_KEY_FILE=data/private-key.dpapi
DISABLE_WINDOWS_DPAPI_PRIVATE_KEY=0
# Optional non-secret strategy override file. Useful on Linux/systemd when the dashboard edits config.
# BOT_CONFIG_FILE=data/bot-config.env

# Optional dashboard password gate. Keep the real password/secret out of Git.
DASHBOARD_PASSWORD=
DASHBOARD_AUTH_SECRET=
DASHBOARD_AUTH_FAIL_REDIRECT=https://www.baidu.com/

# Daily volume markets currently use BTC; 8-hour price range markets currently use Bitcoin.
TARGET_TOPIC=BTC
TARGET_QUESTION_REGEX=BTC.*(Futures Daily Volume|Price|USDT)
TARGET_OUTCOME_REGEX=
STRATEGY=binance_volume_projection

STAKE_USDT=5
STAKE_PER_OUTCOME_USDT=5
MAX_STAKE_USDT=25
MAX_MARKET_STAKE_USDT=25
MAX_BATCH_STAKE_USDT=100
MAX_OUTCOMES_PER_MARKET=12
EVENT_OUTCOME_SELECTION=lowest_odds
EVENT_OUTCOME_COUNT=5
EVENT_OUTCOME_SELECTION_FALLBACK=token_order
EVENT_BUY_MODE=fast
EVENT_DISCOVERY=ws
REST_DISCOVERY_ENABLED=1
REST_DISCOVERY_POLL_MS=1000
AUTO_SELL_ENABLED=1
AUTO_SELL_PROFIT_MULTIPLIER=2
AUTO_SELL_PERCENT=50
AUTO_SELL_POLL_MS=30000
PUSHPLUS_ENABLED=0
PUSHPLUS_TOKEN=
PUSHPLUS_TEMPLATE=markdown
WATCH_FUNDING_MODE=next_batch
BUNDLE_DUE_MARKETS=1
FAST_SKIP_PREFLIGHT=1
FAST_SKIP_DUE_REST_HYDRATION=1
FAST_NONCE_MANAGER=1
PRE_SIGN_FAST_TX=1
PRE_SIGN_WINDOW_MS=5000
PRE_SIGN_RETRY_MS=250
NONCE_SYNC_BEFORE_PRESIGN=1
NONCE_SYNC_MIN_INTERVAL_MS=250
WAIT_FOR_RECEIPT=1
ASYNC_RECEIPT_WATCH=1
RECEIPT_WATCH_TIMEOUT_MS=120000
RECEIPT_WATCH_POLLING_MS=1000
EXECUTION_RETRY_MS=500
EVENT_OPEN_WINDOW_SECONDS=60
FANOUT_BROADCAST=1
BROADCAST_RPC_URLS=
BROADCAST_TIMEOUT_MS=1200
DOCTOR_CHECK_WS=0
GAS_PRICE_GWEI=0.12
FAST_GAS_LIMIT=5000000
BUNDLE_FAST_GAS_LIMIT=12000000
LOG_CHUNK_BLOCKS=5000
WATCH_SCAN_LIMIT=500
EVENT_LOG_LOOKBACK_BLOCKS=50000
REPLAY_LOOKBACK_BLOCKS=50000
MARKET_CATEGORY_ALLOWLIST=
MARKET_CATEGORY_BLOCKLIST=Price
MARKET_TAG_BLOCKLIST=8 hour,automated
MIN_MARKET_CREATED_AT=
MIN_MARKET_DURATION_HOURS=48
WATCH_BUY_EXISTING=0
SLIPPAGE_BPS=800
POLL_MS=500
HOT_POLL_MS=50
PREOPEN_HOT_MS=5000
PREBROADCAST_MS=0
WS_RECEIPT_FALLBACK_MS=0
WS_RECEIPT_FALLBACK_RETRIES=3
WATCH_STARTUP_RETRY_MS=5000
ARM_WAIT_FOR_FUNDING=0
ARM_FUNDING_RETRY_MS=60000
ARM_FUNDING_HOT_RETRY_MS=1000
ARM_FUNDING_HOT_WINDOW_MS=600000
ARM_CATCH_UP_AFTER_FUNDING=1
ARM_CATCH_UP_WINDOW_MS=60000
SCAN_LIMIT=10
OPEN_WINDOW_SECONDS=45
LOOKAHEAD_SECONDS=900
ALLOW_LATE_BUY=0

STATE_FILE=data/seen-markets.json
FILLS_FILE=data/fills.jsonl
