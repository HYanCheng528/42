# Copy to /etc/42space/event-bot.env on the VPS.
# Keep the real file out of Git and chmod it to 600.

DRY_RUN=0
EXECUTE=1
I_UNDERSTAND_42_PRICE_MARKET_RISK=YES
I_AM_NOT_IN_RESTRICTED_JURISDICTION=YES

# Use a small hot wallet only.
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

FORTYTWO_REST_URL=https://rest.ft.42.space
BSC_RPC_URL=https://...
BSC_WS_URL=wss://...
CHAINSTACK_BSC_RPC_URL=
ANKR_BSC_RPC_URL=
CHAINSTACK_BSC_WS_URL=
ANKR_BSC_WS_URL=
ANKR_BSC_WS_RPC_URL=

# Dashboard login gate. Use strong unique values on the VPS.
DASHBOARD_PASSWORD=change-me
DASHBOARD_AUTH_SECRET=change-me-random-32-plus-chars
DASHBOARD_AUTH_FAIL_REDIRECT=https://www.baidu.com/
DASHBOARD_COOKIE_SECURE=1

# Non-secret overrides saved by the dashboard. The systemd units also set this.
BOT_CONFIG_FILE=/opt/42space/data/bot-config.env

STAKE_PER_OUTCOME_USDT=5
EVENT_OUTCOME_COUNT=5
MAX_MARKET_STAKE_USDT=25
MAX_BATCH_STAKE_USDT=100
GAS_PRICE_GWEI=0.12
SELL_GAS_PRICE_GWEI=0.12
OPERATOR_APPROVE_GAS_PRICE_GWEI=0.12
SLIPPAGE_BPS=800
FAST_GAS_LIMIT=5000000
FAST_SELL_GAS_LIMIT=1000000
BUNDLE_FAST_GAS_LIMIT=12000000

EVENT_DISCOVERY=ws
EVENT_BUY_MODE=fast
EVENT_OUTCOME_SELECTION=lowest_odds
EVENT_OUTCOME_SELECTION_FALLBACK=error
MARKET_ADDRESS_BLOCKLIST=
MARKET_QUESTION_BLOCKLIST=
ALLOW_ONCHAIN_ONLY_MARKETS=0
WATCH_FUNDING_MODE=next_batch
MIN_MARKET_DURATION_HOURS=48
EVENT_OPEN_WINDOW_SECONDS=25
EVENT_BUY_DELAY_SECONDS=20
REQUIRE_REST_BEFORE_BUY=1
REQUIRE_REST_STATUS=live
REQUIRE_QUOTE_BEFORE_BUY=1
REQUIRE_CHAIN_MINT_BEFORE_BUY=0

ARM_WAIT_FOR_FUNDING=1
ARM_FUNDING_RETRY_MS=60000
ARM_FUNDING_HOT_RETRY_MS=1000
ARM_FUNDING_HOT_WINDOW_MS=600000
ARM_CATCH_UP_AFTER_FUNDING=0
ARM_CATCH_UP_WINDOW_MS=0

AUTO_SELL_ENABLED=1
AUTO_SELL_POLL_MS=3000
AUTO_SELL_MIN_OUT_MODE=quote
AUTO_SELL_MANUAL_MIN_OUT_USDT=0.000001
AUTO_SELL_ORIGINAL_ENABLED=1
AUTO_SELL_PROFIT_MULTIPLIER=2
AUTO_SELL_PERCENT=50
AUTO_SELL_FIXED_TRAILING_ENABLED=0
AUTO_SELL_TRAILING_START_DELAY_SECONDS=30
AUTO_SELL_TRAILING_ARM_PROFIT_PCT=30
AUTO_SELL_TRAILING_DRAWDOWN_PCT=25
AUTO_SELL_TRAILING_PERCENT=100
AUTO_SELL_ADAPTIVE_TRAILING_ENABLED=0
AUTO_SELL_ADAPTIVE_START_DELAY_SECONDS=30
AUTO_SELL_ADAPTIVE_ARM_PROFIT_PCT=30
AUTO_SELL_ADAPTIVE_EARLY_SECONDS=180
AUTO_SELL_ADAPTIVE_EARLY_DRAWDOWN_PCT=25
AUTO_SELL_ADAPTIVE_WINDOW_SECONDS=120
AUTO_SELL_ADAPTIVE_MIN_SAMPLES=8
AUTO_SELL_ADAPTIVE_SMALL_JUMP_PCT=8
AUTO_SELL_ADAPTIVE_SMALL_RANGE_PCT=80
AUTO_SELL_ADAPTIVE_SMALL_DRAWDOWN_PCT=18
AUTO_SELL_ADAPTIVE_NORMAL_DRAWDOWN_PCT=22
AUTO_SELL_ADAPTIVE_LARGE_JUMP_PCT=18
AUTO_SELL_ADAPTIVE_LARGE_RANGE_PCT=250
AUTO_SELL_ADAPTIVE_LARGE_DRAWDOWN_PCT=28
AUTO_SELL_ADAPTIVE_PERCENT=100
AUTO_SELL_WEAK_EXIT_ENABLED=0
AUTO_SELL_WEAK_EXIT_AFTER_OPEN_SECONDS=1800
AUTO_SELL_WEAK_EXIT_MIN_PEAK_PROFIT_PCT=20
AUTO_SELL_WEAK_EXIT_MAX_CURRENT_PROFIT_PCT=20
AUTO_SELL_WEAK_EXIT_PERCENT=100
AUTO_SELL_BREAKEVEN_ENABLED=0
AUTO_SELL_BREAKEVEN_START_DELAY_SECONDS=30
AUTO_SELL_BREAKEVEN_ARM_PROFIT_PCT=30
AUTO_SELL_BREAKEVEN_EXIT_PROFIT_PCT=3
AUTO_SELL_BREAKEVEN_PERCENT=100
PUSHPLUS_ENABLED=0
PUSHPLUS_TOKEN=
PUSHPLUS_TEMPLATE=markdown

STATE_FILE=data/seen-markets.json
FILLS_FILE=data/fills.jsonl
NOTIFICATION_STATE_FILE=data/notified-markets.json
AUTO_SELL_STATE_FILE=data/auto-sell-seen.json
AUTO_SELL_POSITION_STATE_FILE=data/auto-sell-position-state.json
