# Copy to /etc/42space/event-bot.env on the VPS.
# Keep the real file out of Git and chmod it to 600.

DRY_RUN=0
EXECUTE=1
I_UNDERSTAND_42_PRICE_MARKET_RISK=YES
I_AM_NOT_IN_RESTRICTED_JURISDICTION=YES

# Use a small hot wallet only.
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

FORTYTWO_REST_URL=https://rest.ft.42.space
BSC_RPC_URL=https://...
BSC_WS_URL=wss://...
CHAINSTACK_BSC_RPC_URL=
ANKR_BSC_RPC_URL=
CHAINSTACK_BSC_WS_URL=
ANKR_BSC_WS_URL=
ANKR_BSC_WS_RPC_URL=

# Dashboard login gate. Use strong unique values on the VPS.
DASHBOARD_PASSWORD=change-me
DASHBOARD_AUTH_SECRET=change-me-random-32-plus-chars
DASHBOARD_AUTH_FAIL_REDIRECT=https://www.baidu.com/
DASHBOARD_COOKIE_SECURE=1

# Non-secret overrides saved by the dashboard. The systemd units also set this.
BOT_CONFIG_FILE=/opt/42space/data/bot-config.env

STAKE_PER_OUTCOME_USDT=5
EVENT_OUTCOME_COUNT=5
MAX_MARKET_STAKE_USDT=25
MAX_BATCH_STAKE_USDT=100

EVENT_DISCOVERY=ws
EVENT_BUY_MODE=fast
EVENT_OUTCOME_SELECTION=lowest_odds
EVENT_OUTCOME_SELECTION_FALLBACK=token_order
WATCH_FUNDING_MODE=next_batch
MIN_MARKET_DURATION_HOURS=48

ARM_WAIT_FOR_FUNDING=1
ARM_FUNDING_RETRY_MS=60000
ARM_FUNDING_HOT_RETRY_MS=1000
ARM_FUNDING_HOT_WINDOW_MS=600000
ARM_CATCH_UP_AFTER_FUNDING=1
ARM_CATCH_UP_WINDOW_MS=60000

AUTO_SELL_ENABLED=1
AUTO_SELL_PROFIT_MULTIPLIER=2
AUTO_SELL_PERCENT=50
PUSHPLUS_ENABLED=0
PUSHPLUS_TOKEN=
PUSHPLUS_TEMPLATE=markdown

STATE_FILE=data/seen-markets.json
FILLS_FILE=data/fills.jsonl
AUTO_SELL_STATE_FILE=data/auto-sell-seen.json
